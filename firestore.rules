rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }

    // Matches collection
    match /matches/{matchId} {
      allow read: if true; // Publicly readable for the hub
      allow write: if false; // Only via admin console
    }

    // News collection
    match /news/{newsId} {
      allow read: if true; // Publicly readable for the hub
      allow write: if false; // Only via admin console
    }

    // Scorers collection
    match /scorers/{scorerId} {
      allow read: if true; // Publicly readable for the hub
      allow write: if false; // Only via admin console
    }

    // Fairplay collection
    match /fairplay/{docId} {
      allow read: if true; // Publicly readable for the hub
      allow write: if false; // Only via admin console
    }
  }
}
